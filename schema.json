{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "type": "object",
    "definitions": {
        "rollObject": {
            "type": "object",
            "required": ["name"],
            "properties": {
                "name":{
                    "type": "string"
                },
                "bonus":{
                    "type": "array",
                    "default": 0,
                    "items": 
                    {
                        "type": "integer"
                    },
                    "minItems": 1
                },
                "dice":{
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "integer",
                            "minimum": 1
                        },
                        "minItems": 2,
                        "default": [1,20]
                    },
                    "minItems": 1,
                    "default": [[1,20]]
                },
                "advantage":
                {
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "default": 0
                    },
                    "minItems": 1
                }
            },
            "additionalItems": false
        },
        "rollArray":
        {
            "type": "array",
            "items": 
            {
                "$ref": "#/definitions/rollObject"
            }
        }
    },
    "required": ["settings"],
    "properties": {
        "settings":{
            "type": "object",
            "required": ["binds"],
            "properties": {
                "binds": {
                    "type":"array",
                    "items": {
                        "type": "string"
                    },
                    "minLength": 1
                },
                "animation":{
                    "type": "string",
                    "enum": ["QUICK", "FADE_IN", "RANDOM_NUMBERS"],
                    "default": "RANDOM_NUMBERS"
                },
                "animationSpeed":{
                    "type": "number",
                    "default": 1.25
                },
                "gui":{
                    "type": "object",
                    "required": [],
                    "properties": {
                        "diceResultSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "tabsSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "currentDiceSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "searchSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        }
                    }
                },
                "searchType":{
                    "type": "string",
                    "enum": ["STRICT", "FLEXIBLE"],
                    "default": "FLEXIBLE"
                }
            },
            "additionalProperties": false
        }
    },
    "patternProperties": {
        "^(?!settings$).*": {
            "$ref": "#/definitions/rollArray"
        }
    },
    "additionalItems": false
}