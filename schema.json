{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "type": "object",
    "definitions": {
        "rollObject": {
            "type": "object",
            "required": ["name", "bonus", "dice"],
            "properties": {
                "name":{
                    "type": "string"
                },
                "bonus":{
                    "type": "integer"
                },
                "dice":{
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "minItems": 2,
                    "maxItems": 2
                }
            },
            "additionalItems": false
        },
        "rollArray":
        {
            "type": "array",
            "items": 
            {
                "$ref": "#/definitions/rollObject"
            }
        }
    },
    "required": ["settings"],
    "properties": {
        "settings":{
            "type": "object",
            "required": ["binds", "animation", "animationSpeed", "gui"],
            "properties": {
                "binds": {
                    "type":"array",
                    "items": {
                        "type": "string"
                    }
                },
                "animation":{
                    "type": "string",
                    "enum": ["QUICK", "FADE_IN", "RANDOM_NUMBERS"],
                    "default": "RANDOM_NUMBERS"
                },
                "animationSpeed":{
                    "type": "number",
                    "default": 1.25
                },
                "gui":{
                    "type": "object",
                    "required": ["diceResultSizeMul", "tabsSizeMul", "currentDiceSizeMul", "searchSizeMul"],
                    "properties": {
                        "diceResultSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "tabsSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "currentDiceSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        },
                        "searchSizeMul":
                        {
                            "type": "number",
                            "default": 1
                        }
                    }
                }
            },
            "additionalProperties": false
        }
    },
    "patternProperties": {
        "^(?!settings$).*": {
            "$ref": "#/definitions/rollArray"
        }
    },
    "additionalItems": false
}